{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/p/:id", "destination": "/p" },
    { "source": "/01/:gtin/21/:serial", "destination": "/p" }
  ],
  "headers": [
    {
      "source": "/passports/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "application/ld+json; charset=utf-8" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
